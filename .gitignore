cat > .gitignore <<'EOF'
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
.installed.cfg
pip-wheel-metadata/

# Virtual environments
venv/
ENV/
env/
.venv/
env.bak/
venv.bak/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
pytest_cache/
cover/

# Django
*.log
local_settings.py
db.sqlite3
media/
staticfiles/

# IDEs / editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# PyInstaller
*.manifest
*.spec

# mypy
.mypy_cache/
.dmypy.json

# celery
celerybeat-schedule

# Sphinx
docs/_build/

# dotenv / env files
.env
.env.*
EOF